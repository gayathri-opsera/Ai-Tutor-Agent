# AI Tutor Agent — Environment Configuration Template
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git. All secrets must stay out of version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=ai_tutor_local_password
DATABASE_URL=postgresql://ai_tutor:ai_tutor_local_password@postgres:5432/ai_tutor

# ── Object Storage ────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-tutor-content

# ── Vector DB ─────────────────────────────────────────────────────────────────
WEAVIATE_API_KEY=local-dev-key
WEAVIATE_URL=http://weaviate:8080

# ── AI Providers (at least one required for LLM generation) ──────────────────
# Anthropic (default provider)
ANTHROPIC_API_KEY=

# OpenAI (fallback provider / embeddings)
OPENAI_API_KEY=

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Groq (optional fast inference)
GROQ_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set to 'true' for local dev with mock users, 'false' for real Keycloak
VITE_AUTH_MOCK=true
AUTH_MOCK=true
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=ai-tutor
VITE_KEYCLOAK_CLIENT=ai-tutor-frontend

# ── Service Internal Token ────────────────────────────────────────────────────
# Token used for service-to-service calls. Set a strong random value in production.
SERVICE_INTERNAL_TOKEN=change-me-in-production

# ── Chat Retention ────────────────────────────────────────────────────────────
# Chat sessions older than this many days are purged automatically (default: 7)
CHAT_RETENTION_DAYS=7
