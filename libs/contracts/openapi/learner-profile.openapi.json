        "summary": "Get Course Progress",
        "description": "Return per-lesson completion state for a user within a knowledge base.",
        "operationId": "get_course_progress_api_v1_learner_course__kb_id__progress_get",
        "parameters": [
          {
            "name": "kb_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Kb Id"
            }
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "demo-user",
