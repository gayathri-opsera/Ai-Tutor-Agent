    "/api/v1/learner/lesson": {
      "post": {
        "tags": [
          "learner"
        ],
        "summary": "Save Lesson",
        "description": "Record a lesson (document) as completed or uncompleted for a user.",
        "operationId": "save_lesson_api_v1_learner_lesson_post",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "demo-user",
              "title": "User Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
