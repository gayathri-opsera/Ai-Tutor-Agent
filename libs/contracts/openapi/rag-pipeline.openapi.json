{
  "openapi": "3.1.0",
  "info": {
    "title": "RAG Pipeline",
    "version": "1.0.0"
  },
  "paths": {
    "/api/internal/rag/ingest": {
      "post": {
        "tags": [
          "rag"
        ],
        "summary": "Ingest Document",
        "description": "Accept chunks and schedule embedding + vector-store upsert as a background task.",
        "operationId": "ingest_document_api_internal_rag_ingest_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/internal/rag/retrieve": {
      "post": {
        "tags": [
          "rag"
        ],
        "summary": "Retrieve",
        "operationId": "retrieve_api_internal_rag_retrieve_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RetrieveRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetrieveResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/internal/rag/debug/vector-store": {
      "get": {
        "tags": [
          "rag"
        ],
        "summary": "Debug Vector Store",
        "description": "Debug: inspect stored vectors to diagnose score issues.",
        "operationId": "debug_vector_store_api_internal_rag_debug_vector_store_get",
        "parameters": [
          {
            "name": "kb_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "",
              "title": "Kb Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/internal/rag/suggested-questions": {
      "get": {
        "tags": [
          "rag"
        ],
        "summary": "Suggested Questions",
        "description": "Return 3-5 course-contextual suggested questions for the chat landing screen.\n\nRetrieves representative chunks from the knowledge base, then calls the\nLLM gateway to generate relevant questions. Falls back to a static list\nif the LLM or RAG pipeline is unavailable.",
        "operationId": "suggested_questions_api_internal_rag_suggested_questions_get",
        "parameters": [
          {
            "name": "knowledge_base_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Knowledge Base Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Health check with Weaviate connectivity status and vector sync metrics.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChunkResult": {
        "properties": {
          "chunk_id": {
            "type": "string",
            "title": "Chunk Id"
          },
          "text": {
            "type": "string",
            "title": "Text"
          },
          "document_id": {
            "type": "string",
            "title": "Document Id"
          },
          "document_title": {
            "type": "string",
            "title": "Document Title"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "metadata": {
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "chunk_id",
          "text",
          "document_id",
          "document_title",
          "score"
        ],
        "title": "ChunkResult",
        "description": "A single document chunk returned by the RAG retrieval endpoint."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IngestChunk": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text"
          },
          "chunk_index": {
            "type": "integer",
            "title": "Chunk Index",
            "default": 0
          },
          "metadata": {
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "IngestChunk",
        "description": "A single text chunk submitted for embedding and vector-store upsert."
      },
      "IngestRequest": {
        "properties": {
          "document_id": {
            "type": "string",
            "title": "Document Id"
          },
          "knowledge_base_id": {
            "type": "string",
            "title": "Knowledge Base Id"
          },
          "document_title": {
            "type": "string",
            "title": "Document Title"
          },
          "chunks": {
            "items": {
              "$ref": "#/components/schemas/IngestChunk"
            },
            "type": "array",
            "title": "Chunks"
          },
          "force": {
            "type": "boolean",
            "title": "Force",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "document_id",
          "knowledge_base_id",
          "document_title",
          "chunks"
        ],
        "title": "IngestRequest",
        "description": "Request body for POST /api/internal/rag/ingest."
      },
      "RetrieveRequest": {
        "properties": {
          "query": {
            "type": "string",
            "title": "Query"
          },
          "knowledge_base_id": {
            "type": "string",
            "title": "Knowledge Base Id"
          },
          "top_k": {
            "type": "integer",
            "maximum": 50.0,
            "minimum": 1.0,
            "title": "Top K",
            "default": 5
          },
          "filters": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Filters"
          },
          "use_hybrid": {
            "type": "boolean",
            "title": "Use Hybrid",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "query",
          "knowledge_base_id"
        ],
        "title": "RetrieveRequest",
        "description": "Request body for POST /api/internal/rag/retrieve."
      },
      "RetrieveResponse": {
        "properties": {
          "chunks": {
            "items": {
              "$ref": "#/components/schemas/ChunkResult"
            },
            "type": "array",
            "title": "Chunks"
          },
          "query_embedding": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Query Embedding"
          }
        },
        "type": "object",
        "required": [
          "chunks",
          "query_embedding"
        ],
        "title": "RetrieveResponse",
        "description": "Response envelope for POST /api/internal/rag/retrieve."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}