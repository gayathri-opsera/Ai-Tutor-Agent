{
  "openapi": "3.1.0",
  "info": {
    "title": "Assessment Engine",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/assessments": {
      "post": {
        "tags": [
          "assessments"
        ],
        "summary": "Create Assessment",
        "operationId": "create_assessment_api_v1_assessments_post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAssessment"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "assessments"
        ],
        "summary": "List Assessments",
        "operationId": "list_assessments_api_v1_assessments_get",
        "parameters": [
          {
            "name": "knowledge_base_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Knowledge Base Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/assessments/generate": {
      "post": {
        "tags": [
          "assessments"
        ],
        "summary": "Generate Assessment",
        "description": "LLM-based question generation from knowledge base content.",
        "operationId": "generate_assessment_api_v1_assessments_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/assessments/results/{user_id}": {
      "get": {
        "tags": [
          "assessments"
        ],
        "summary": "Get User Results",
        "operationId": "get_user_results_api_v1_assessments_results__user_id__get",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "User Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/assessments/compare/{user_id}": {
      "get": {
        "tags": [
          "assessments"
        ],
        "summary": "Get Pre Post Comparison",
        "description": "Return pre/post comparison \u2014 improvement_percentage shows learning gain.",
        "operationId": "get_pre_post_comparison_api_v1_assessments_compare__user_id__get",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "User Id"
            }
          },
          {
            "name": "knowledge_base_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Knowledge Base Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/assessments/{assessment_id}/take": {
      "get": {
        "tags": [
          "assessments"
        ],
        "summary": "Take Assessment",
        "description": "Learner-safe endpoint \u2014 returns questions WITHOUT correct_index.",
        "operationId": "take_assessment_api_v1_assessments__assessment_id__take_get",
        "parameters": [
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Assessment Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/assessments/{assessment_id}": {
      "get": {
        "tags": [
          "assessments"
        ],
        "summary": "Get Assessment",
        "description": "Full assessment including correct answers \u2014 for admin/creator use.",
        "operationId": "get_assessment_api_v1_assessments__assessment_id__get",
        "parameters": [
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Assessment Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/assessments/{assessment_id}/submit": {
      "post": {
        "tags": [
          "assessments"
        ],
        "summary": "Submit",
        "description": "Score answers and return per-question feedback.",
        "operationId": "submit_api_v1_assessments__assessment_id__submit_post",
        "parameters": [
          {
            "name": "assessment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Assessment Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitAnswers"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateAssessment": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title"
          },
          "assessment_type": {
            "type": "string",
            "title": "Assessment Type",
            "default": "pre"
          },
          "knowledge_base_id": {
            "type": "string",
            "title": "Knowledge Base Id",
            "default": ""
          },
          "questions": {
            "items": {
              "type": "object"
            },
            "type": "array",
            "title": "Questions"
          }
        },
        "type": "object",
        "required": [
          "title",
          "questions"
        ],
        "title": "CreateAssessment"
      },
      "GenerateRequest": {
        "properties": {
          "knowledge_base_id": {
            "type": "string",
            "title": "Knowledge Base Id"
          },
          "topic": {
            "type": "string",
            "title": "Topic"
          },
          "count": {
            "type": "integer",
            "maximum": 20.0,
            "minimum": 1.0,
            "title": "Count",
            "default": 5
          },
          "difficulty": {
            "type": "string",
            "title": "Difficulty",
            "default": "medium"
          },
          "assessment_type": {
            "type": "string",
            "title": "Assessment Type",
            "default": "quiz"
          },
          "auto_create": {
            "type": "boolean",
            "title": "Auto Create",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "knowledge_base_id",
          "topic"
        ],
        "title": "GenerateRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "SubmitAnswers": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id",
            "default": "demo-user"
          },
          "answers": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Answers"
          }
        },
        "type": "object",
        "required": [
          "answers"
        ],
        "title": "SubmitAnswers"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}