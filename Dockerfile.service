# Shared base Dockerfile for all Python FastAPI services.
# Build with:  docker build --build-arg SERVICE=llm-gateway -f Dockerfile.service -t ai-tutor-{service} .
ARG SERVICE=llm-gateway
ARG PORT=8000

FROM python:3.13-slim AS base

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── Shared libraries ────────────────────────────────────────────────────
COPY libs/kafka/src         /app/libs/kafka/src
COPY libs/kafka/requirements.txt /app/libs/kafka/requirements.txt
COPY libs/vector-db/src     /app/libs/vector-db/src
COPY libs/auth/src          /app/libs/auth/src
COPY libs/cache/src         /app/libs/cache/src
COPY libs/logging/src       /app/libs/logging/src
COPY libs/metrics/src       /app/libs/metrics/src
COPY libs/contracts/src     /app/libs/contracts/src
COPY libs/model/src         /app/libs/model/src
COPY libs/secrets/src       /app/libs/secrets/src
COPY libs/db/src            /app/libs/db/src

# ── Service deps ─────────────────────────────────────────────────────────
ARG SERVICE
COPY services/${SERVICE}/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# ── Service source ───────────────────────────────────────────────────────
COPY services/${SERVICE}/src /app/src

# ── Python path includes all shared libs ────────────────────────────────
ENV PYTHONPATH=/app:/app/libs/auth/src:/app/libs/model/src:/app/libs/secrets/src:/app/libs/db/src:/app/libs/kafka/src:/app/libs/vector-db/src:/app/libs/cache/src:/app/libs/logging/src:/app/libs/metrics/src:/app/libs/contracts/src

ARG PORT=8000
ENV PORT=${PORT}

HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:${PORT}/health || exit 1

CMD ["sh", "-c", "uvicorn src.main:app --host 0.0.0.0 --port ${PORT}"]
