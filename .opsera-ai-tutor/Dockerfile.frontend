# Build stage — do NOT set NODE_ENV before npm install
# devDependencies (vite, tsc) are required to build production artifacts
FROM node:24-alpine AS build

WORKDIR /app

# Install deps first (uses cache when package.json unchanged)
COPY frontend/package*.json ./
RUN npm ci --ignore-scripts

# Build production bundle
COPY frontend/ .
RUN npm run build

# Runtime stage — serve built assets via nginx (non-root, port 8080)
FROM nginxinc/nginx-unprivileged:alpine AS runtime

# Copy built assets from build stage
COPY --from=build /app/dist /usr/share/nginx/html

# Copy nginx server config — only server {} block, no pid directive here
COPY .opsera-ai-tutor/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:8080/ || exit 1
